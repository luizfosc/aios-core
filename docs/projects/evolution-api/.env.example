# Evolution API
AUTHENTICATION_API_KEY=change-me-to-a-secure-key
SERVER_URL=https://your-domain.com

# Database (PostgreSQL)
DATABASE_PROVIDER=postgresql
DATABASE_NAME=evolution
DATABASE_USERNAME=evolution
DATABASE_PASSWORD=evolution_secret
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_CONNECTION_URI=postgresql://evolution:evolution_secret@postgres:5432/evolution?schema=public

# Cache (Redis)
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_LOCAL_ENABLED=false
