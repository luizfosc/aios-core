# Cademi credentials
CADEMI_EMAIL=seu@email.com
CADEMI_PASSWORD=sua-senha

# Base URL of the Cademi platform (without trailing slash)
CADEMI_BASE_URL=https://renanvieira.cademi.com.br

# Output directory for downloads (default: downloads)
CADEMI_OUTPUT_DIR=downloads

# Video quality: best, 1080p, 720p, 480p, 360p (default: best)
CADEMI_QUALITY=best

# Max retries for HTTP requests (default: 3)
CADEMI_MAX_RETRIES=3

# HTTP request timeout in seconds (default: 30)
CADEMI_TIMEOUT=30
